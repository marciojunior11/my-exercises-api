generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Equipamento {
  id   Int    @id @default(autoincrement()) @map("id")
  nome String @map("nome") @db.VarChar(255)

  @@map("tb_equipamentos")
}

model GrupoMuscular {
  id   Int    @id @default(autoincrement()) @map("id")
  nome String @map("nome") @db.VarChar(255)

  @@map("tb_grupos_musculares")
}

model Modalidade {
  id   Int    @id @default(autoincrement()) @map("id")
  nome String @map("nome") @db.VarChar(255)

  @@map("tb_modalidades")
}
